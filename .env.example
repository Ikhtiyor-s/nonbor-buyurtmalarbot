# ===================================
# Seller Bot Configuration
# Copy this file to .env and fill in your values
# ===================================

# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ===================================
# Telegram Bot Settings
# ===================================

# Bot Token - @BotFather dan oling
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Admin IDs - vergul bilan ajrating (database dan tashqari qo'shimcha adminlar)
# Telegram ID olish uchun @userinfobot ga yozing
ADMIN_IDS=123456789,987654321

# ===================================
# External API Settings (ixtiyoriy)
# ===================================

# Sizning API URL va kaliti
EXTERNAL_API_URL=https://your-api.com/api/v1
EXTERNAL_API_KEY=your-api-key-here

# Polling interval (sekundlarda) - webhook bo'lmasa ishlatiladi
POLL_INTERVAL=30
